# =============================================================================
# Slides Generator by KPMG — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=kpmg_slides
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=slides_generator
DATABASE_URL=postgresql+asyncpg://kpmg_slides:secure_password_here@db:5432/slides_generator

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=random-secret-key-here

# ── LLM Providers ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=gemma4:latest

# ── Application ──────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
FRONTEND_URL=http://localhost:3000
